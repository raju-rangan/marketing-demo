############ GCP ENVIRONMENT CONFIGURATIONS ############
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global
MODELS_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_BUCKET_ARTIFACTS=your-artifacts-bucket

############ LLM MODELS FOR AGENTS ############
LLM_GEMINI_MODEL_MARKETING_ANALYST=gemini-3.1-pro-preview
MODEL_NAME=gemini-3.1-pro-preview
LLM_GEMINI_MODEL_EVALUATION=gemini-2.5-flash

############ MODELS FOR GENMEDIA ############
IMAGE_GENERATION_MODEL=gemini-3.1-flash-image-preview
STORYBOARD_GENERATION_MODEL=gemini-3.1-flash-image-preview
VIDEO_GENERATION_MODEL=veo-3.1-generate-001
AUDIO_TTS_GENERATION_MODEL=gemini-2.5-pro-tts
AUDIO_TTS_VOICE_NAME=Charon
IMAGE_DEFAULT_ASPECT_RATIO=16:9

############ IMAGE GENERATION SETTINGS ############
IMAGE_GENERATION_TENACITY_ATTEMPTS=3
IMAGE_GENERATION_EVAL_REATTEMPTS=1
IMAGE_GENERATION_CONCURRENCY_LIMIT=4
IMAGE_GENERATION_RETRY_DELAY_SECONDS=2

############ AGENT STATE/SESSION ############
DEMO_COMPANY_NAME=SecureVision
AGENT_VERSION=5.20260410.1
MARKETING_ANALYST_DATASTORE_CLOUD_BUCKET=your-artifacts-bucket
CAMPAIGNS_CONFIG_URL=gs://your-artifacts-bucket/data_campaigns.xml
SELECTED_CAMPAIGN_FILE_NAME=selected_campaign_name
SELECTED_ASSET_SHEET_FILE_NAME=selected_asset_sheet_name
SESSION_STATE_FILE_NAME=session_state

############ BIGQUERY ############
BQ_DATASET=retail_analytics

############ SAFETY NETS ############
BACKUP_CATALOG_IMAGE_URL=https://storage.googleapis.com/your-artifacts-bucket/logo.png
BACKUP_LOGO_IMAGE_URL=https://storage.googleapis.com/your-artifacts-bucket/logo.png

############ GOOGLE ADS ############
DEVELOPER_TOKEN=insert-developer-token-if-available
PROJECT_ID=your-project-id

############ NO NEED TO CHANGE ############
GOOGLE_GENAI_USE_VERTEXAI=TRUE

############ JPMC BRAND ASSETS ############
JPMC_LOGO_URI=gs://your-artifacts-bucket/samples/chase_logo.png
SAPPHIRE_CARD_URI=gs://your-artifacts-bucket/samples/chase_sapphire_card_img.webp
FREEDOM_CARD_URI=gs://your-artifacts-bucket/samples/chase_sapphire_card_img.webp
PRIVATE_WEALTH_CARD_URI=gs://your-artifacts-bucket/samples/chase_sapphire_card_img.webp

############ CDN CONFIGURATION ############
# Set this to your Load Balancer IP or custom domain to use CDN for HTML assets
CDN_HOST=

############ TELEMETRY ############
LOGS_BUCKET_NAME=your-artifacts-bucket
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
